# ── AquaGuard Environment ─────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
#
# All API keys are OPTIONAL for core functionality:
#   - Without GEMINI: AI summaries use a built-in rule-based fallback.
#   - Without ELEVENLABS: Voice playback is skipped (the rest works).
#   - NASA POWER: Free, no key required.

# ── Google Gemini (for AI-powered compliance summaries) ───────────────
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── ElevenLabs TTS (for voice playback of summaries) ──────────────────
# Sign up at https://elevenlabs.io (free tier available)
ELEVEN_LABS_API_KEY=

# ── Google Maps (for the interactive river map) ───────────────────────
# Optional: frontend defaults to a demo mode if not set.
# Get a key at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=

# ── Application ───────────────────────────────────────────────────────
# The backend runs on port 8000 by default (no env var needed).
# The frontend dev server runs on :5173 with :8080 as production.
