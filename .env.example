# ── AquaGuard Environment ─────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
#
# All API keys are OPTIONAL for core functionality:
#   - Without GEMINI: AI summaries use a built-in rule-based fallback.
#   - Without API_AUTH_KEY: Backend auth is disabled (dev mode).
#   - NASA POWER: Free, no key required.

# ── Google Gemini (for AI-powered compliance summaries) ───────────────
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Backend API Authentication Key ─────────────────────────────────────
# If set, all API requests must include X-API-Key header with this value.
# Leave empty to disable authentication (development mode only).
API_AUTH_KEY=

# ── Allowed CORS Origins ──────────────────────────────────────────────
# Comma-separated list of allowed frontend origins for browser requests.
# Default: http://localhost:5173,http://localhost:8080
ALLOWED_ORIGINS=

# ── Google Maps (for the interactive river map) ───────────────────────
# Optional: frontend defaults to a demo mode if not set.
# Get a key at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=

# ── Backend API URL (for AI-powered summaries) ────────────────────────
# Optional: set to your deployed backend URL for AI compliance summaries.
# Example: https://aquagaurd.onrender.com
VITE_APP_URL=

# ── Google Analytics (optional) ──────────────────────────────────────
# Set your GA4 measurement ID for page-view analytics.
# Example: VITE_GA_ID=G-XXXXXXXXXX
VITE_GA_ID=
